# =============================================================================
# Invoice Processing Pipeline — Environment Variables
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values inside .env
# 3. NEVER commit .env to version control (.gitignore already excludes it)
# =============================================================================


# -----------------------------------------------------------------------------
# STEP 1 — Email / IMAP (step1_download.py)
# -----------------------------------------------------------------------------

# Your full email address
IMAP_USERNAME=your_email@gmail.com

# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# Do NOT use your regular Gmail password here.
IMAP_PASSWORD=your_app_password_here

# IMAP server hostname
IMAP_SERVER=imap.gmail.com

# The Gmail label (folder) that contains your invoice emails
IMAP_LABEL=accounting


# -----------------------------------------------------------------------------
# SHARED — Base storage path (used by all steps)
# -----------------------------------------------------------------------------

# Absolute path to the root folder where all invoice data is stored.
# Step 1 creates a DD-MM-YYYY subfolder here for each day's downloads.
#
# Windows:  INVOICE_BASE_FOLDER=C:\Users\YourName\Documents\Invoices
# macOS:    INVOICE_BASE_FOLDER=/Users/yourname/invoices
# Linux:    INVOICE_BASE_FOLDER=/home/yourname/invoices
#
# Leave blank to default to an "invoices/" folder in the current directory.
INVOICE_BASE_FOLDER=./invoices


# -----------------------------------------------------------------------------
# STEP 2 — Extraction & Rename (step2_rename.py)
# -----------------------------------------------------------------------------

# Path to the supplier lookup Excel file
# Required columns: VAT_Number, Supplier_Name (or set custom names below)
SUPPLIERS_FILE=./invoices/suppliers.xlsx

# Path to the location/cost-centre lookup Excel file
# Required columns: LOCATION_CODE, ADDRESS, KEYWORDS
LOCATIONS_FILE=./invoices/locations.xlsx

# Folder where unresolvable / corrupt PDFs are moved for manual review
TRASH_FOLDER=./invoices/UNPROCESSABLE

# Column names in suppliers.xlsx — change if your spreadsheet uses different headers
SUPPLIER_VAT_COL=VAT_Number
SUPPLIER_NAME_COL=Supplier_Name

# Column names in locations.xlsx — change if your spreadsheet uses different headers
LOC_CODE_COL=LOCATION_CODE
LOC_ADDR_COL=ADDRESS
LOC_KEYS_COL=KEYWORDS


# -----------------------------------------------------------------------------
# STEP 3 — Dual Folder Organisation (step3_organize.py)
# -----------------------------------------------------------------------------

# Root of the "by supplier" archive tree
# Structure: {root}/{location_folder}/{supplier}/{date}/{invoice}.pdf
ORGANIZED_BY_SUPPLIER=./invoices/organized/by_supplier

# Root of the "by date" index tree
# Structure: {root}/{location_folder}/{date}/{supplier}_{invoice}.pdf
ORGANIZED_BY_DATE=./invoices/organized/by_date
